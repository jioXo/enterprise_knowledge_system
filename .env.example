# 数据库配置
DATABASE_URL=postgresql://username:password@localhost:5432/enterprise_knowledge
SQLALCHEMY_DATABASE_URL=postgresql://username:password@localhost:5432/enterprise_knowledge_test

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# API 密钥
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 向量数据库配置
VECTOR_DB_PATH=./data/vector_db
VECTOR_DB_TYPE=chroma  # chroma, milvus, faiss

# 文档存储配置
RAW_DOCS_PATH=./data/raw_docs
PROCESSED_DOCS_PATH=./data/processed_docs

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=True
SECRET_KEY=your_secret_key_here

# 文档同步配置
SYNC_INTERVAL=3600  # 秒
DOCUMENT_PLATFORMS=feishu,confluence,local
MAX_DOCUMENT_SIZE=10485760  # 10MB

# Agent 配置
AGENT_MODEL_NAME=gpt-4
EMBEDDING_MODEL_NAME=text-embedding-ada-002
MAX_TOKENS=4000
TEMPERATURE=0.7